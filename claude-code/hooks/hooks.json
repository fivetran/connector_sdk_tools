{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT/hooks/log-skill-use.sh\" \"$CLAUDE_PLUGIN_ROOT/.claude-plugin/plugin.json\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A file was just modified. If it was a connector file (connector.py, configuration.json, or requirements.txt), briefly remind the user they can run /test-connector to verify their changes. Keep the reminder to one sentence. If the file is unrelated to a connector, say nothing."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT/hooks/log-skill-use.sh\" \"$CLAUDE_PLUGIN_ROOT/.claude-plugin/plugin.json\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT/hooks/log-skill-use.sh\" \"$CLAUDE_PLUGIN_ROOT/.claude-plugin/plugin.json\""
          }
        ]
      }
    ]
  }
}
